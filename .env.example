# Farmore wallet runtime config. Copy to .env.local to override. No secrets here.

# LOCAL DEV: leave both UNSET. The app calls the same-origin "/__resolver" path and Vite
# proxies it to the resolver below — this avoids the browser's cross-origin (CORS) block.
# Only change VITE_RESOLVER_TARGET if you run a different resolver locally.
# VITE_RESOLVER_TARGET=http://84.8.134.52:8080

# PRODUCTION ONLY: the absolute resolver URL the built app fetches directly. This requires
# the resolver to send CORS headers, and (if the wallet is on HTTPS) the resolver to be on
# HTTPS too (no mixed content). Leave unset for local dev.
# VITE_RESOLVER_URL=https://resolver.example.com
